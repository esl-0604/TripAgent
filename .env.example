# === Flow (Madrascheck) ===
FLOW_API_KEY=your-flow-api-key-here
FLOW_API_BASE_URL=https://api.flow.team

# === Dropbox ===
# Short-lived access token (4h). Auto-refreshed using refresh_token below.
DROPBOX_ACCESS_TOKEN=
# App credentials from Dropbox App Console → Settings
DROPBOX_APP_KEY=your-dropbox-app-key-here
DROPBOX_APP_SECRET=your-dropbox-app-secret-here
# Long-lived refresh token obtained via tasks/setup_dropbox_refresh.py
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token-here
# Team member ID (dbmid:...) — required if the app has team scope
DROPBOX_TEAM_MEMBER_ID=dbmid:your-team-member-id
DROPBOX_APP_FOLDER_NAME=MaestroAgent

# === Trip Agent (Slack bot) ===
# Bot User OAuth Token (xoxb-): 봇 자체가 채널에서 읽기/쓰기 할 때 사용
TRIP_BOT_TOKEN=xoxb-your-trip-agent-bot-token-here
# User OAuth Token (xoxp-): 이은상 본인 명의로 동작 (예: 본인이 올린 메시지 삭제)
TRIP_USER_TOKEN=xoxp-your-trip-agent-user-token-here
# App-Level Token (xapp-): Socket Mode 리스너가 Slack에 WebSocket 연결할 때 사용
TRIP_APP_TOKEN=xapp-your-trip-agent-app-token-here
# Slack channel ID for #출장일지
TRIP_CHANNEL_ID=C0AT6HAUW57
# Slack channel ID for #학회강의
LECTURE_CHANNEL_ID=
